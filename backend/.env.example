# Local-first config. By default the app uses a SQLite file (no Docker/Postgres needed),
# so you usually don't need a .env file at all.

# Optional: override the SQLite location or point at another DB.
# DATABASE_URL=sqlite:///./fittracker.db

# Optional: extra allowed CORS origins (comma-separated). LAN IPs are already allowed.
# CORS_ORIGINS=http://localhost:8081,http://localhost:19006

DEBUG=true
